NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres connection for Drizzle migrations + the server DB client.
# Supabase -> Project Settings -> Database -> Connection string.
# Use the DIRECT / session connection (port 5432) so DDL migrations run in a
# transaction; the transaction pooler (6543) is a later scale optimisation.
# Put the real value in .env.local (gitignored) — never commit it.
DATABASE_URL=

# Comma-separated emails allowed into the /admin tool (blueprint §5). NOT
# NEXT_PUBLIC_ — server-only. Create the matching auth users in the Supabase
# dashboard (Auth -> Users -> Add user, auto-confirm); there is no open signup.
# e.g. ADMIN_EMAILS=ana@example.com,marko@example.com
ADMIN_EMAILS=
