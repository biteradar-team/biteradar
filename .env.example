NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public origin, used for absolute SEO URLs (sitemap, robots,
# OpenGraph/canonical). No trailing slash. Set this to the production domain in
# Vercel env once biteradar.com is live; if unset it defaults to
# http://localhost:3000 (fine for local dev / build).
NEXT_PUBLIC_SITE_URL=

# Postgres connection for Drizzle migrations + the server DB client.
# Supabase -> Project Settings -> Database -> Connection string.
# Use the DIRECT / session connection (port 5432) so DDL migrations run in a
# transaction; the transaction pooler (6543) is a later scale optimisation.
# Put the real value in .env.local (gitignored) — never commit it.
DATABASE_URL=

# Comma-separated emails allowed into the /admin tool (blueprint §5). NOT
# NEXT_PUBLIC_ — server-only. Create the matching auth users in the Supabase
# dashboard (Auth -> Users -> Add user, auto-confirm); there is no open signup.
# e.g. ADMIN_EMAILS=ana@example.com,marko@example.com
ADMIN_EMAILS=

# MapTiler key for the maps (blueprint §"Mapa" — MapLibre + MapTiler, USVOJENO):
# the admin coordinate picker AND the public map (home list + „Blizu mene" +
# location profiles). Free tier: 100k map loads/mo. NEXT_PUBLIC_ = shipped to the
# browser by design; restrict it by domain in the MapTiler dashboard. If unset,
# the admin form falls back to manual lat/lng inputs and the public map is simply
# hidden (the list keeps working).
# Get one free at https://cloud.maptiler.com -> Account -> Keys.
NEXT_PUBLIC_MAPTILER_KEY=

# Supabase SERVICE ROLE key — server-side photo upload to Storage only (bypasses
# RLS). DANGER: full-access key. NEVER NEXT_PUBLIC_, never commit, never send to
# the browser. Supabase -> Project Settings -> API -> service_role. Also run the
# one-time bucket setup in docs/storage-setup.sql.
SUPABASE_SERVICE_ROLE_KEY=
