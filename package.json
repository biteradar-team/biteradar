{
  "name": "biteradar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:smoke": "node --env-file=.env.local --import tsx src/db/smoke.ts",
    "db:search-smoke": "node --env-file=.env.local --import tsx src/search/search-smoke.ts",
    "db:seed-dishes": "node --env-file=.env.local --import tsx src/services/seed-dishes.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "drizzle-orm": "^0.45.2",
